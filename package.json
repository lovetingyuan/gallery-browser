{
  "name": "gallery-browser",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "npm run build && wrangler dev",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "deploy": "npm run build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "lint": "oxlint -c .oxlintrc.json --vue-plugin --fix .",
    "format": "oxfmt ."
  },
  "dependencies": {
    "@iconify/vue": "^5.0.0",
    "@tailwindcss/vite": "^4.2.1",
    "glightbox": "^3.3.1",
    "tailwindcss": "^4.2.1",
    "vue": "^3.5.29",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.26.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/tsconfig": "^0.8.1",
    "daisyui": "^5.5.19",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.0.6",
    "vue-tsc": "^3.2.5",
    "wrangler": "^4.71.0"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
